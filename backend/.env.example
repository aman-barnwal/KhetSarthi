# Server-side only. Never expose privileged secrets to the frontend.
MONGO_URL="mongodb://localhost:27017"
DB_NAME="krishiyog"
CORS_ORIGINS="*"

# Auth
JWT_SECRET="<random-64-char-hex>"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="<strong-password>"

# AI / Vision (provider-independent via AIService adapter)
AI_PROVIDER="gemini"            # gemini | groq
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3-flash-preview"
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# Market prices (data.gov.in Agmarknet - Current Daily Mandi Prices)
DATA_GOV_API_KEY=""

# Optional future integrations (leave empty until configured)
SPEECH_TO_TEXT_API_KEY=""       # browser-native Web Speech API used in v1
TEXT_TO_SPEECH_API_KEY=""       # browser-native speechSynthesis used in v1
TRANSLATION_API_KEY=""          # static UI uses localization files
MAPS_API_KEY=""                 # OpenStreetMap-based, no key required in v1
NOTIFICATION_API_KEY=""         # in-app notification center used in v1
STORAGE_BUCKET_URL=""           # images stored as base64 in DB in v1
